---
import type { Locale } from "@data/i18n";
import { getDictionary } from "@data/i18n";

interface Props {
  post: {
    slug: string;
    title: string;
    description?: string;
    date: string;
    tags?: string[];
    readingTime?: number;
    lang?: string;
  };
  locale: Locale;
}

const { post, locale } = Astro.props;
const dict = getDictionary(locale);
const prefix = locale === "en" ? "/en" : "";
const href = `${prefix}/posts/${post.slug}`;

const formattedDate = new Date(post.date).toLocaleDateString(
  locale === "en" ? "en-US" : "pt-BR",
  { year: "numeric", month: "long", day: "numeric" }
);
---

<a href={href} class="group block border-t border-neutral-800 py-8 transition-colors hover:bg-neutral-900/30" data-reveal>
  <div class="flex flex-col gap-4 w-full">
    <div class="flex items-center flex-wrap gap-4 text-xs font-bold tracking-[0.2em] text-neutral-500 uppercase">
      {post.tags && post.tags.length > 0 && (
        <span>{post.tags[0]}</span>
      )}
      <span>—</span>
      <time datetime={post.date}>{formattedDate}</time>
      {post.readingTime && (
        <>
          <span>—</span>
          <span>{post.readingTime} {dict.posts.minutesOfReading}</span>
        </>
      )}
    </div>

    <h3 class="text-2xl md:text-3xl font-light tracking-tight text-white group-hover:opacity-70 transition-opacity">
      {post.title}
    </h3>

    {post.description && (
      <p class="text-neutral-400 font-light leading-relaxed max-w-2xl line-clamp-2">
        {post.description}
      </p>
    )}
  </div>
</a>
