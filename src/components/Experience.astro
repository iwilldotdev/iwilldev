---
import type { Locale } from "@data/i18n";
import { getDictionary } from "@data/i18n";
import { getJobs } from "@data/jobs";
import { Plus } from "lucide-astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = getDictionary(locale);
const jobs = getJobs(locale);
---

<section class="py-40 md:py-64 px-6 md:px-12 bg-black" id="experiencia" data-reveal>
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-24">
    <div class="md:col-span-4">
      <h2 class="font-bold tracking-[0.2em] uppercase text-white sticky top-32 text-xs">
        {dict.experience.title}
      </h2>
    </div>
    
    <div class="md:col-span-8">
      <div class="flex flex-col w-full max-w-[1040px]">
        {jobs.map((job) => (
          <div class="accordion-item group flex flex-col border-b border-neutral-800 overflow-hidden cursor-pointer transition-all duration-500" data-accordion-item>
            <div class="flex items-center justify-between min-h-[96px] py-6" data-accordion-header>
              <div>
                <h3 class="font-manrope text-3xl md:text-4xl font-light text-white">
                  {job.company}
                </h3>
                <span class="text-xs uppercase tracking-widest text-neutral-500">
                  {job.jobTitle} • {job.startDate} — {job.endDate}
                </span>
              </div>
              <div class="expand-icon flex items-center justify-center w-12 h-12 transition-transform duration-500 text-white" data-accordion-icon>
                <Plus class="w-8 h-8 font-extralight" strokeWidth={1} />
              </div>
            </div>
            <div class="accordion-content" data-accordion-content>
              <div class="text-lg text-neutral-400 font-light leading-relaxed max-w-2xl py-6 prose-p:mb-4" set:html={job.description} />
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
