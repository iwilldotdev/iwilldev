---
import type { Locale } from "@data/i18n";
import { getDictionary, localePath } from "@data/i18n";
import { getPostLanguageSwitchHref } from "@lib/posts";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = getDictionary(locale);

const navItems = [
  { label: dict.nav.home, href: localePath("/", locale) },
  { label: dict.nav.posts, href: localePath("/posts", locale) },
];

const otherLocale = locale === "pt" ? "en" : "pt";
const postSwitchHref = getPostLanguageSwitchHref(Astro.url.pathname, locale);
const switchHref =
  postSwitchHref ??
  (locale === "pt"
    ? "/en" + (Astro.url.pathname === "/" ? "" : Astro.url.pathname)
    : Astro.url.pathname.replace(/^\/en/, "") || "/");
---

<nav class="fixed top-0 w-full z-[70] bg-black/80 backdrop-blur-xl flex justify-between items-center px-6 md:px-12 py-6">
  <a href={localePath("/", locale)} class="font-manrope font-bold text-xl tracking-tighter text-white">
    iwill.dev
  </a>

  <!-- Desktop Nav -->
  <div class="hidden md:flex gap-12 items-center">
    {navItems.map((item) => {
      const isPosts = item.href.includes("/posts");
      const isHomePath = Astro.url.pathname === "/" || Astro.url.pathname === "/en";
      const isActive =
        (Astro.url.pathname.includes("/posts") && isPosts) || (isHomePath && !isPosts);
      
      return (
        <a 
          href={item.href} 
          class={`font-manrope font-light tracking-tight text-sm uppercase transition-colors hover:text-white ${isActive ? "text-white font-bold border-b border-white pb-1" : "text-neutral-400"}`}
        >
          {item.label}
        </a>
      );
    })}

    <!-- Language Switcher -->
    <a href={switchHref} class="font-manrope font-light tracking-tight text-sm uppercase text-neutral-400 hover:text-white transition-colors" aria-label="Switch language">
      {otherLocale.toUpperCase()}
    </a>
  </div>

  <!-- Mobile Actions -->
  <div class="flex items-center gap-4 md:hidden">
    <a href={switchHref} class="font-manrope text-sm uppercase text-neutral-400 hover:text-white">
      {otherLocale.toUpperCase()}
    </a>
    <button
      type="button"
      class="relative w-12 h-12 flex-shrink-0"
      aria-label="Menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-hamburger
    >
      <span class="hamburger-top absolute left-1/2 -translate-x-1/2 block w-6 h-px bg-white" style="top: 25%"></span>
      <span class="hamburger-mid absolute left-1/2 -translate-x-1/2 block w-6 h-px bg-white" style="top: 50%"></span>
      <span class="hamburger-bottom absolute left-1/2 -translate-x-1/2 block w-6 h-px bg-white" style="top: 75%"></span>
    </button>
  </div>
</nav>

<!-- Mobile full-page menu -->
<div
  id="mobile-menu"
  data-mobile-menu
  class="fixed inset-0 z-[60] bg-black hidden flex-col items-center justify-center gap-10 px-6"
  aria-hidden="true"
>
  {navItems.map((item) => {
    const isPosts = item.href.includes("/posts");
    const isHomePath = Astro.url.pathname === "/" || Astro.url.pathname === "/en";
    const isActive =
      (Astro.url.pathname.includes("/posts") && isPosts) || (isHomePath && !isPosts);

    return (
      <a
        href={item.href}
        data-mobile-nav-link
        class={`font-manrope text-4xl font-light tracking-tight uppercase transition-opacity hover:opacity-70 ${
          isActive ? "text-white" : "text-neutral-400"
        }`}
      >
        {item.label}
      </a>
    );
  })}
  <a
    href={switchHref}
    data-mobile-nav-link
    class="font-manrope text-sm uppercase tracking-widest text-neutral-500 hover:text-white transition-colors mt-4"
  >
    {otherLocale.toUpperCase()}
  </a>
</div>
