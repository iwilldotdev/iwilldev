---
import type { Locale } from "@data/i18n";
import { getDictionary } from "@data/i18n";
import { coreSkills, aiSkills, secondarySkills } from "@data/skills";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = getDictionary(locale);
---

<section class="py-40 md:py-64 px-6 md:px-12 bg-[#0a0a0a]" id="expertise" data-reveal>
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-24">
    <div class="md:col-span-4">
      <h2 class="font-bold tracking-[0.2em] uppercase text-white sticky top-32 text-xs">
        {dict.skillsEditorial.title}
      </h2>
    </div>
    
    <div class="md:col-span-8">
      <div class="space-y-20">
        <div>
          <h3 class="text-xs font-bold tracking-[0.3em] uppercase mb-10 text-neutral-500">
            {dict.skillsEditorial.coreTitle}
          </h3>
          <div class="flex flex-wrap gap-x-8 gap-y-6 text-3xl md:text-5xl font-extralight text-white">
            {coreSkills.map((skill, i) => (
              <>
                <span>{skill.label}</span>
                {i < coreSkills.length - 1 && <span class="text-neutral-600">/</span>}
              </>
            ))}
          </div>
        </div>

        <div>
           <h3 class="text-xs font-bold tracking-[0.3em] uppercase mb-10 text-neutral-500">
             {dict.skillsEditorial.aiTitle}
           </h3>
           <div class="flex flex-wrap gap-x-6 gap-y-4 text-xl md:text-2xl font-light text-neutral-400">
             {aiSkills.map((skill) => (
               <span>{skill.label}</span>
             ))}
           </div>
        </div>

        <div>
           <h3 class="text-xs font-bold tracking-[0.3em] uppercase mb-10 text-neutral-500">
             {dict.skillsEditorial.secondaryTitle}
           </h3>
           <div class="flex flex-wrap gap-x-6 gap-y-4 text-xl md:text-2xl font-light text-neutral-400">
             {secondarySkills.map((skill) => (
               <span>{skill.label}</span>
             ))}
           </div>
        </div>
        
        <blockquote class="border-l border-neutral-700 pl-8 mt-12 bg-black/20 py-6 pr-6">
          <p class="text-2xl font-light text-white italic leading-relaxed mb-4">"{dict.skillsEditorial.quote}"</p>
          <cite class="text-neutral-500 tracking-widest text-sm">— {dict.skillsEditorial.quoteAuthor}</cite>
        </blockquote>
      </div>
    </div>
  </div>
</section>
