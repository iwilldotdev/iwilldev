---
import type { Locale } from "@data/i18n";
import { getDictionary } from "@data/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = getDictionary(locale);
---

<section class="py-40 md:py-64 px-6 md:px-12 bg-black" id="certificados" data-reveal>
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-24">
    <div class="md:col-span-4">
      <h2 class="font-bold tracking-[0.2em] uppercase text-white sticky top-32 text-xs">
        {dict.certifications.title}
      </h2>
    </div>
    
    <div class="md:col-span-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {dict.certifications.items.map((item) => (
          <div class="group p-8 border border-neutral-800 bg-[#0a0a0a] hover:border-neutral-500 transition-colors block">
            <span class="text-xs font-bold text-neutral-500 block mb-2 uppercase">{item.issuer}</span>
            <h4 class="text-2xl font-light text-white group-hover:opacity-80 transition-opacity">{item.name}</h4>
            <span class="text-xs text-neutral-600 mt-4 block">{item.date}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
