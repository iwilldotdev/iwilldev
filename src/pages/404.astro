---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";
import Footer from "@components/Footer.astro";
import type { Locale } from "@data/i18n";
import { getDictionary } from "@data/i18n";
import { ArrowLeft } from "@lucide/astro";

const locale: Locale = "pt";
const dict = getDictionary(locale);
---

<BaseLayout locale={locale} title={`404 — ${dict.notFound.title}`}>
  <Nav locale={locale} />

  <main class="min-h-screen bg-black flex flex-col justify-center py-20">
    <div class="px-8 max-w-7xl mx-auto w-full text-center" data-reveal>
      <div class="max-w-xl mx-auto">
        <span class="block font-manrope text-[clamp(6rem,15vw,12rem)] font-light text-white opacity-5 leading-none mb-8 -tracking-[0.05em]" data-reveal>404</span>
        <h1 class="font-manrope text-3xl md:text-5xl font-light text-white tracking-tight mb-6" data-reveal>{dict.notFound.title}</h1>      
        <p class="text-xl text-neutral-400 font-light leading-relaxed mb-12" data-reveal>
          {dict.notFound.description}
        </p>
        <a href="/" class="group inline-flex items-center gap-4 text-xs font-bold tracking-[0.2em] text-neutral-500 uppercase hover:text-white transition-colors" data-reveal>
          <ArrowLeft class="w-5 h-5 transform group-hover:-translate-x-2 transition-transform" />
          {dict.notFound.backHome}
        </a>
      </div>
    </div>
  </main>

  <Footer locale={locale} />
</BaseLayout>
