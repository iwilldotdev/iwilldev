---
import type { Locale } from "@data/i18n";
import { getDictionary } from "@data/i18n";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  locale?: Locale;
}

const {
  title,
  description,
  ogImage = "/photo.webp",
  locale = "pt",
} = Astro.props;

const dict = getDictionary(locale);
const pageTitle = title || dict.meta.title;
const pageDescription = description || dict.meta.description;
const htmlLang = locale === "en" ? "en" : "pt-BR";
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={htmlLang} class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="author" content={dict.meta.author} />
    <meta
      name="keywords"
      content="portfolio, frontend, react, typescript, css, desenvolvedor, programação, conteúdo técnico, learn in public"
    />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:site_name" content="iwill.dev" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl.href} />

    <!-- Favicons -->
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Fonts: Manrope (unified) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@200;300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700;FILL@0..1&display=swap"
      rel="stylesheet"
    />

    <!-- Tailwind Config -->
    <script src="https://cdn.tailwindcss.com?plugins=typography,forms,container-queries" is:inline></script>
    <script id="tailwind-config" is:inline>
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              outline: "#666666",
              "on-secondary-container": "#FFFFFF",
              "on-surface": "#FFFFFF",
              "tertiary-fixed": "#969696",
              "on-secondary-fixed": "#FFFFFF",
              tertiary: "#969696",
              "surface-container-low": "#0a0a0a",
              "on-secondary": "#000000",
              "primary-container": "#FFFFFF",
              "tertiary-container": "#333333",
              "on-tertiary-container": "#FFFFFF",
              "on-background": "#FFFFFF",
              "inverse-primary": "#000000",
              "on-tertiary-fixed": "#000000",
              "on-tertiary": "#969696",
              "surface-variant": "#1a1a1a",
              "surface-bright": "#1a1a1a",
              "on-primary-container": "#000000",
              background: "#000000",
              "on-error": "#ffffff",
              "on-secondary-fixed-variant": "#969696",
              "primary-fixed": "#FFFFFF",
              "on-tertiary-fixed-variant": "#969696",
              "primary-fixed-dim": "#e2e2e2",
              "secondary-fixed": "#969696",
              "on-surface-variant": "#969696",
              "on-primary-fixed": "#000000",
              "surface-dim": "#050505",
              "surface-container-lowest": "#000000",
              surface: "#000000",
              "secondary-fixed-dim": "#666666",
              primary: "#FFFFFF",
              "inverse-on-surface": "#000000",
              "secondary-container": "#1a1a1a",
              "on-primary-fixed-variant": "#969696",
              "surface-container-highest": "#333333",
              error: "#ffb4ab",
              "tertiary-fixed-dim": "#666666",
              "error-container": "#93000a",
              secondary: "#969696",
              "on-error-container": "#ffdad6",
              "surface-container": "#0a0a0a",
              "outline-variant": "#333333",
              "inverse-surface": "#FFFFFF",
              "on-primary": "#000000",
              "surface-tint": "#FFFFFF",
              "surface-container-high": "#121212",
            },
            fontFamily: {
              headline: ["Manrope", "sans-serif"],
              body: ["Manrope", "sans-serif"],
              label: ["Manrope", "sans-serif"],
            },
            borderRadius: {
              DEFAULT: "0.125rem",
              lg: "0.25rem",
              xl: "0.5rem",
              full: "0.75rem",
            },
          },
        },
      };
    </script>
    <style is:global>
      body {
        font-family: "Manrope", sans-serif;
        background-color: #000000;
        color: #ffffff;
        scroll-behavior: smooth;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      .material-symbols-outlined {
        font-variation-settings:
          "FILL" 0,
          "wght" 300,
          "GRAD" 0,
          "opsz" 24;
      }
      .text-reveal {
        opacity: 0;
        transform: translateY(20px);
        animation: reveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }
      @keyframes reveal {
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      /* Accordions with data-accordion-* are driven by JS (click/tap). */
      [data-accordion-item] .accordion-content {
        overflow: hidden;
      }
      [data-accordion-item].is-open .expand-icon {
        transform: rotate(45deg);
      }
    </style>

    <!-- GSAP + ScrollTrigger + Lenis -->
    <script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js" is:inline></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js" is:inline></script>
    <script src="https://cdn.jsdelivr.net/npm/@studio-freight/lenis@1/bundled/lenis.min.js" is:inline></script>
  </head>

  <body class="bg-surface selection:bg-primary selection:text-on-primary">
    <slot />

    <script is:inline>
      ;(function () {
        'use strict'

        // ─── Pearl Easing & Duration ─────────────────────
        var EASE = 'power2.out'
        var DUR_FAST = 0.15
        var DUR_NORMAL = 0.3
        var DUR_SLOW = 0.5
        var DUR_REVEAL = 0.8

        var lenis = null

        function prefersReducedMotion() {
          return window.matchMedia('(prefers-reduced-motion: reduce)').matches
        }

        function refreshScrollTriggers() {
          if (typeof ScrollTrigger !== 'undefined') {
            ScrollTrigger.refresh()
          }
        }

        // ─── Init: Lenis (Pearl config) + GSAP ──────────
        function init() {
          if (typeof gsap === 'undefined') return
          gsap.registerPlugin(ScrollTrigger)

          if (typeof Lenis !== 'undefined') {
            lenis = new Lenis({
              duration: 1.2,
              easing: function (t) {
                return Math.min(1, 1.001 - Math.pow(2, -10 * t))
              },
              orientation: 'vertical',
              gestureOrientation: 'vertical',
              smoothWheel: true,
              smoothTouch: false,
              wheelMultiplier: 1,
              touchMultiplier: 2,
            })

            lenis.on('scroll', ScrollTrigger.update)

            // Lenis smooth-scroll uses virtual position; proxy keeps ScrollTrigger in sync.
            ScrollTrigger.scrollerProxy(document.documentElement, {
              scrollTop: function (value) {
                if (arguments.length) {
                  lenis.scrollTo(value, { immediate: true })
                }
                return lenis.scroll
              },
              getBoundingClientRect: function () {
                return {
                  top: 0,
                  left: 0,
                  width: window.innerWidth,
                  height: window.innerHeight,
                }
              },
            })

            ScrollTrigger.addEventListener('refresh', function () {
              lenis.resize()
            })

            gsap.ticker.add(function (time) {
              lenis.raf(time * 1000)
            })
            gsap.ticker.lagSmoothing(0)
          }
        }

        // ─── Section Fade In (Pearl signature) ──────────
        function revealSections() {
          var els = gsap.utils.toArray('[data-reveal]')
          els.forEach(function (el) {
            gsap.fromTo(
              el,
              { autoAlpha: 0, y: 40 },
              {
                autoAlpha: 1,
                y: 0,
                duration: DUR_REVEAL,
                ease: EASE,
                scrollTrigger: {
                  trigger: el,
                  start: 'top 85%',
                  toggleActions: 'play none none none',
                  invalidateOnRefresh: true,
                },
              }
            )
          })
        }

        // ─── Nav Link Hover (Pearl slide-up) ────────────
        function navLinkHovers() {
          var links = gsap.utils.toArray('.pearl-nav-link')
          links.forEach(function (link) {
            var inner = link.querySelector('.pearl-nav-link__inner')
            if (!inner) return

            link.addEventListener('mouseenter', function () {
              gsap.to(inner, { y: -22, duration: DUR_NORMAL, ease: EASE })
            })
            link.addEventListener('mouseleave', function () {
              gsap.to(inner, { y: 0, duration: DUR_NORMAL, ease: EASE })
            })
          })
        }

        // ─── CTA Button Hover (Pearl scale + arrow) ────
        function ctaButtonHovers() {
          var buttons = gsap.utils.toArray('[data-cta-hover]')
          buttons.forEach(function (btn) {
            var arrow = btn.querySelector('.cta-arrow')

            btn.addEventListener('mouseenter', function () {
              gsap.to(btn, { scale: 1.02, duration: DUR_FAST, ease: EASE })
              if (arrow) gsap.to(arrow, { x: 4, duration: DUR_FAST, ease: EASE })
            })
            btn.addEventListener('mouseleave', function () {
              gsap.to(btn, { scale: 1, duration: DUR_FAST, ease: EASE })
              if (arrow) gsap.to(arrow, { x: 0, duration: DUR_FAST, ease: EASE })
            })
          })
        }

        // ─── Accordion Toggle (Pearl expand/collapse) ───
        function accordionInteractions(instant) {
          var items = document.querySelectorAll('[data-accordion-item]')
          items.forEach(function (item) {
            var header = item.querySelector('[data-accordion-header]')
            var content = item.querySelector('[data-accordion-content]')
            var icon = item.querySelector('[data-accordion-icon]')
            if (!header || !content) return

            var isOpen = false

            function setClosed() {
              item.classList.remove('is-open')
              isOpen = false
              if (instant) {
                content.style.height = '0'
                content.style.opacity = '0'
                if (icon) icon.style.transform = ''
                return
              }
              if (typeof gsap === 'undefined') return
              gsap.to(content, {
                height: 0,
                autoAlpha: 0,
                duration: DUR_NORMAL,
                ease: EASE,
                onComplete: refreshScrollTriggers,
              })
              if (icon) gsap.to(icon, { rotation: 0, duration: DUR_NORMAL, ease: EASE })
            }

            function setOpen() {
              item.classList.add('is-open')
              isOpen = true
              if (instant) {
                content.style.height = 'auto'
                content.style.opacity = '1'
                if (icon) icon.style.transform = 'rotate(45deg)'
                return
              }
              if (typeof gsap === 'undefined') return
              gsap.set(content, { height: 'auto', overflow: 'hidden' })
              var h = content.offsetHeight
              gsap.fromTo(
                content,
                { height: 0, autoAlpha: 0, overflow: 'hidden' },
                {
                  height: h,
                  autoAlpha: 1,
                  duration: DUR_NORMAL,
                  ease: EASE,
                  onComplete: refreshScrollTriggers,
                }
              )
              if (icon) gsap.to(icon, { rotation: 45, duration: DUR_NORMAL, ease: EASE })
            }

            if (instant) {
              content.style.overflow = 'hidden'
              content.style.height = '0'
              content.style.opacity = '0'
            } else if (typeof gsap !== 'undefined') {
              gsap.set(content, { height: 0, overflow: 'hidden', autoAlpha: 0 })
            }

            header.addEventListener('click', function () {
              if (isOpen) setClosed()
              else setOpen()
            })
          })
        }

        // ─── Hamburger Toggle (Pearl 3-lines → X) ──────
        function hamburgerToggle(instant) {
          var btn = document.querySelector('[data-hamburger]')
          var menu = document.querySelector('[data-mobile-menu]')
          if (!btn || !menu) return

          var isOpen = false
          var top = btn.querySelector('.hamburger-top')
          var mid = btn.querySelector('.hamburger-mid')
          var bottom = btn.querySelector('.hamburger-bottom')

          function setIconOpen() {
            if (instant || typeof gsap === 'undefined') {
              if (top) {
                top.style.top = '50%'
                top.style.transform = 'translateX(-50%) translateY(-1px) rotate(45deg)'
              }
              if (mid) {
                mid.style.opacity = '0'
                mid.style.width = '1px'
              }
              if (bottom) {
                bottom.style.top = '50%'
                bottom.style.transform = 'translateX(-50%) translateY(-1px) rotate(-45deg)'
              }
              return
            }
            gsap.to(top, { top: '50%', y: -1, rotation: 45, duration: DUR_NORMAL, ease: 'power2.inOut' })
            gsap.to(mid, { width: 1, autoAlpha: 0, duration: DUR_FAST, ease: 'power2.inOut' })
            gsap.to(bottom, { top: '50%', y: -1, rotation: -45, duration: DUR_NORMAL, ease: 'power2.inOut' })
          }

          function setIconClosed() {
            if (instant || typeof gsap === 'undefined') {
              if (top) {
                top.style.top = '25%'
                top.style.transform = 'translateX(-50%)'
              }
              if (mid) {
                mid.style.opacity = '1'
                mid.style.width = '1.5rem'
              }
              if (bottom) {
                bottom.style.top = '75%'
                bottom.style.transform = 'translateX(-50%)'
              }
              return
            }
            gsap.to(top, { top: '25%', y: 0, rotation: 0, duration: DUR_NORMAL, ease: 'power2.inOut' })
            gsap.to(mid, { width: '100%', autoAlpha: 1, duration: DUR_FAST, ease: 'power2.inOut' })
            gsap.to(bottom, { top: '75%', y: 0, rotation: 0, duration: DUR_NORMAL, ease: 'power2.inOut' })
          }

          function openMenu() {
            isOpen = true
            btn.setAttribute('aria-expanded', 'true')
            menu.setAttribute('aria-hidden', 'false')
            document.body.style.overflow = 'hidden'
            setIconOpen()
            if (instant || typeof gsap === 'undefined') {
              menu.style.display = 'flex'
              menu.style.opacity = '1'
              return
            }
            gsap.fromTo(menu, { autoAlpha: 0, y: -20 }, { autoAlpha: 1, y: 0, display: 'flex', duration: DUR_NORMAL, ease: EASE })
          }

          function closeMenu() {
            isOpen = false
            btn.setAttribute('aria-expanded', 'false')
            menu.setAttribute('aria-hidden', 'true')
            document.body.style.overflow = ''
            setIconClosed()
            if (instant || typeof gsap === 'undefined') {
              menu.style.opacity = '0'
              menu.style.display = 'none'
              return
            }
            gsap.to(menu, {
              autoAlpha: 0,
              y: -20,
              duration: DUR_NORMAL,
              ease: EASE,
              onComplete: function () {
                gsap.set(menu, { display: 'none' })
              },
            })
          }

          if (instant || typeof gsap === 'undefined') {
            menu.style.display = 'none'
            menu.style.opacity = '0'
          } else {
            gsap.set(menu, { display: 'none', autoAlpha: 0 })
          }

          btn.addEventListener('click', function () {
            if (isOpen) closeMenu()
            else openMenu()
          })

          menu.querySelectorAll('[data-mobile-nav-link]').forEach(function (link) {
            link.addEventListener('click', function () {
              if (isOpen) closeMenu()
            })
          })

          document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape' && isOpen) closeMenu()
          })
        }

        // ─── Main Init ─────────────────────────────────
        document.addEventListener('DOMContentLoaded', function () {
          var reducedMotion = prefersReducedMotion()

          if (reducedMotion) {
            document.querySelectorAll('[data-reveal]').forEach(function (el) {
              el.style.visibility = 'visible'
              el.style.opacity = '1'
            })
          } else {
            init()
          }

          // Small delay to let DOM settle
          setTimeout(function () {
            if (!reducedMotion) {
              revealSections()
              navLinkHovers()
              ctaButtonHovers()
              refreshScrollTriggers()
              requestAnimationFrame(refreshScrollTriggers)
              window.addEventListener('load', refreshScrollTriggers, { once: true })
              window.addEventListener('resize', refreshScrollTriggers)
            }
            hamburgerToggle(reducedMotion)
            accordionInteractions(reducedMotion)
            if (!reducedMotion) {
              setTimeout(refreshScrollTriggers, 400)
            }
          }, 100)
        })
      })()
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
